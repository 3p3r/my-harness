{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-opencode@latest"],
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (2x3090)",
      "options": {
        "baseURL": "http://192.168.1.65:9090/v1",
        "apiKey": "sk-no-key-required"
      },
      "models": {
        "qwen": {
          "name": "Qwen3.5-35B-A3B (UD-Q4_K_XL)"
        }
      }
    }
  },
  "model": "local/qwen",
  "mcp": {
    "contextplus": {
      "timeout": 15000,
      "enabled": true,
      "command": ["npx", "-y", "contextplus"],
      "type": "local",
      "environment": {
        "OLLAMA_API_KEY": "does-not-matter",
        "OLLAMA_HOST": "192.168.1.65",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "OLLAMA_CHAT_MODEL": "artifish/llama3.2-uncensored"
      }
    }
  }
}
