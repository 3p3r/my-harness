{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    }
  },
  "plugin": [
    "opencode-lcm",
    "context-mode",
    "opencode-agent-browser",
    "opencode-pty",
    "oh-my-openagent@latest",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "http://deezr:4000/v1"
      },
      "models": {
        "thinking": {
          "id": "thinking",
          "name": "Thinking (Gemma 4 Q8)",
          "family": "gemma",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 262144,
            "output": 16384
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        },
        "coding": {
          "id": "coding",
          "name": "Coding (Qwen3.6 35B Q8)",
          "family": "qwen",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 262144,
            "output": 16384
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "research": {
          "id": "research",
          "name": "Research (Dual Qwen3 14B Q8)",
          "family": "qwen",
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  }
}
