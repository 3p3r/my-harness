{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "disabled_skills": [
    "git-master"
  ],
  "default_run_agent": "sisyphus",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/deepseek-v4-pro",
      "reasoningEffort": "medium",
      "permission": {
        "bash": {
          "git": "deny"
        }
      },
      "fallback_models": [
        "litellm/my-opus"
      ]
    },
    "hephaestus": {
      "model": "litellm/my-opus",
      "reasoningEffort": "medium",
      "allow_non_gpt_model": true,
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "oracle": {
      "model": "litellm/my-sonnet",
      "reasoningEffort": "medium",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "librarian": {
      "model": "litellm/my-haiku",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "explore": {
      "model": "litellm/my-sonnet",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "multimodal-looker": {
      "model": "litellm/my-opus",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "prometheus": {
      "model": "litellm/my-opus",
      "reasoningEffort": "xhigh",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "metis": {
      "model": "litellm/my-opus",
      "reasoningEffort": "low",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "momus": {
      "model": "litellm/my-opus",
      "reasoningEffort": "high",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "atlas": {
      "model": "litellm/my-sonnet",
      "reasoningEffort": "low",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "sisyphus-junior": {
      "model": "litellm/my-sonnet",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    },
    "OpenCode-Builder": {
      "model": "litellm/my-sonnet",
      "reasoningEffort": "medium",
      "permission": {
        "bash": {
          "git": "deny"
        }
      }
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "litellm/my-opus"
    },
    "ultrabrain": {
      "model": "litellm/my-sonnet"
    },
    "deep": {
      "model": "litellm/my-opus"
    },
    "artistry": {
      "model": "litellm/my-haiku"
    },
    "quick": {
      "model": "litellm/my-sonnet"
    },
    "unspecified-low": {
      "model": "litellm/my-sonnet"
    },
    "unspecified-high": {
      "model": "litellm/my-opus"
    },
    "writing": {
      "model": "litellm/my-haiku"
    }
  },
  "start_work": {
    "auto_commit": false
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  }
}
