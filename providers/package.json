{
  "name": "@my-harness/providers",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint --fix",
    "format": "biome format --write"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.45",
    "ai": "^4.0.0",
    "exponential-backoff": "^3.1.3",
    "queue": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
